    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const lastSuccessStr = $json.last_success_at;\nconst status = $json.status;\nconst workflowTag = $json.workflow_tag;\n\nlet shouldRun = false;\nlet reason = \"\";\n\nif (!lastSuccessStr) {\n  shouldRun = true;\n  reason = 'No previous success record';\n} else {\n  const lastSuccessDate = new Date(lastSuccessStr);\n  const now = new Date();\n\n  const isToday = \n    lastSuccessDate.getUTCFullYear() === now.getUTCFullYear() &&\n    lastSuccessDate.getUTCMonth() === now.getUTCMonth() &&\n    lastSuccessDate.getUTCDate() === now.getUTCDate();\n\n  shouldRun = (!isToday || status === 'error') && status !== 'running';\n  \n  if (!isToday) {\n    reason = 'Last success was not today';\n  } else if (status === 'error') {\n    reason = 'Last run failed';\n  } else {\n    reason = 'Already done or running';\n  }\n}\n\nreturn { \n  workflowTag, \n  should_run: shouldRun, \n  reason: reason \n};"
      },
